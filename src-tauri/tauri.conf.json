{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Freedao",
  "version": "0.7.0",
  "identifier": "com.freedao.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Freedao",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "center": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "category": "Productivity",
    "shortDescription": "距离自由还差多少 · 自由度导航",
    "longDescription": "Freedao 是独立创业者的财务自由导航系统。不是记账软件，而是告诉你被动收入覆盖生活支出之前还差多少。本地优先，数据不上云，BYOK 接入 AI 辅助分类。",
    "copyright": "© 2026 画伞 yangfan",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
